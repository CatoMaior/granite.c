{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Granite.c",
      "type": "shell",
      "command": "make -j",
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Granite.c (debug)",
      "type": "shell",
      "command": "make debug -j",
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Clean build",
      "type": "shell",
      "command": "make clean",
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}